{
  "permissions": {
    "allow": [
      "Bash(acli jira workitem view *)",
      "Bash(acli jira workitem search *)",
      "Bash(openspec status *)",
      "Bash(graphify *)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:md)",
      "Bash(pnpm test:run)",
      "Bash(pnpm build)",
      "Bash(npx tsc *)",
      "Bash(npx playwright show-report)",
      "Bash(npx supabase gen types *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph update --skip-flows --repo \"/Users/nlong/Projects/drum-charter\" || true",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph status --repo \"/Users/nlong/Projects/drum-charter\" || echo 'Not a git repo, skipping'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
