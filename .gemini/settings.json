{
  "experimental": {
    "enableAgents": true
  },
  "hooks": {
    "BeforeTool": [],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-session-start.sh",
            "name": "code-review-graph status",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-update.sh",
            "name": "code-review-graph update",
            "timeout": 30000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve",
        "--tools",
        "build_or_update_graph_tool,detect_changes_tool,get_review_context_tool,get_impact_radius_tool,get_affected_flows_tool,query_graph_tool,semantic_search_nodes_tool,refactor_tool,get_architecture_overview_tool,list_communities_tool,list_flows_tool,list_graph_stats_tool,get_docs_section_tool"
      ],
      "cwd": "/Users/nlong/Projects/drum-charter"
    }
  }
}
